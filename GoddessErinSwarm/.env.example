# Copy to .env and fill in locally. Never commit .env.
# GitHub: create repo "GoddessErinSwarm" as Private before pushing.

# --- Open WebUI → Ollama ---
OLLAMA_BASE_URL=http://ollama:11434

# --- OpenClaw gateway (generate a long random secret) ---
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-string

# --- TTS (VoxCPM2 / "FoxCPM2" stack name) ---
# Optional: Hugging Face token if you use gated models or higher rate limits.
HUGGING_FACE_HUB_TOKEN=
# Voice-design prefix: natural-language voice description in parentheses at the start of synthesis text.
# Keep this in .env only; do not commit personal or explicit content.
GODDESS_AURA_VOICE=(Adult female voice, warm, confident, smooth pacing, clear articulation)

# Model id on the Hub (VoxCPM2 weights download on first run; stays in Docker volume).
VOXCPM_MODEL_ID=openbmb/VoxCPM2

# --- Tabby (optional profile: tabby) ---
TABBY_MODEL=StarCoder2-3B
TABBY_CHAT_MODEL=Qwen2.5-Coder-1.5B-Instruct
